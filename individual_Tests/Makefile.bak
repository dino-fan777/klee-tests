# ═══════════════════════════════════════════════════════════════
# KLEE Global Test Suite — Makefile
#
# Sits alongside klee_test_helper.h, delegates to subdirectories.
#
# Directory structure:
#   ./klee_test_helper.h
#   ./Makefile              ← this file
#   ./open/test_01.c ... test_20.c + Makefile
#   ./write/test_01.c ... test_13.c + Makefile
#
# Usage:
#   make run_open              run all open() tests
#   make run_open_01           run open/test_01 only
#   make run_write             run all write() tests
#   make run_write_05          run write/test_05 only
#   make run_all               run everything
#   make compile_open          compile open() tests only
#   make compile_write         compile write() tests only
#   make compile_all           compile everything
#   make clean                 nuke everything
#   make clean_open            clean open/ only
#   make clean_write           clean write/ only
# ═══════════════════════════════════════════════════════════════

# ── Colors ────────────────────────────────────────────────────
RED      = \033[1;31m
GREEN    = \033[1;32m
YELLOW   = \033[1;33m
CYAN     = \033[1;36m
WHITE    = \033[1;37m
DIM      = \033[2m
RESET    = \033[0m
BG_GREEN = \033[42;1;37m
BG_RED   = \033[41;1;37m
BG_CYAN  = \033[46;1;37m

# ── Suites ────────────────────────────────────────────────────
SUITES = open write

.PHONY: run_all compile_all clean $(addprefix run_,$(SUITES)) \
        $(addprefix compile_,$(SUITES)) $(addprefix clean_,$(SUITES))

# ═══════════════════════════════════════════════════════════════
#  run_all / compile_all / clean
# ═══════════════════════════════════════════════════════════════

run_all:
	@echo ""
	@echo "$(BG_CYAN) KLEE FULL TEST SUITE $(RESET)"
	@echo ""
	@for suite in $(SUITES); do \
		echo "$(CYAN)═══════════════════════════════════════════════════════════$(RESET)"; \
		echo "$(WHITE)  Suite: $$suite$(RESET)"; \
		echo "$(CYAN)═══════════════════════════════════════════════════════════$(RESET)"; \
		$(MAKE) -C $$suite run; \
		echo ""; \
	done

compile_all:
	@for suite in $(SUITES); do \
		echo "$(CYAN)  Compiling $$suite ...$(RESET)"; \
		$(MAKE) -C $$suite compile; \
	done

clean:
	@echo ""
	@echo "$(CYAN)═══════════════════════════════════════════════════════════$(RESET)"
	@echo "$(WHITE)  Cleaning all suites$(RESET)"
	@echo "$(CYAN)═══════════════════════════════════════════════════════════$(RESET)"
	@for suite in $(SUITES); do \
		$(MAKE) -C $$suite clean; \
	done

# ═══════════════════════════════════════════════════════════════
#  Per-suite targets: run_open, compile_open, clean_open, etc.
# ═══════════════════════════════════════════════════════════════

run_open:
	@$(MAKE) -C open run

run_write:
	@$(MAKE) -C write run

compile_open:
	@$(MAKE) -C open compile

compile_write:
	@$(MAKE) -C write compile

clean_open:
	@$(MAKE) -C open clean

clean_write:
	@$(MAKE) -C write clean

# ═══════════════════════════════════════════════════════════════
#  Individual test targets: run_open_01, run_write_13, etc.
#
#  Pattern: run_<suite>_<number>
#  Delegates to: make -C <suite> run_<number>
# ═══════════════════════════════════════════════════════════════

run_open_%:
	@$(MAKE) -C open compile
	@$(MAKE) -C open run_$*

run_write_%:
	@$(MAKE) -C write compile
	@$(MAKE) -C write run_$*
